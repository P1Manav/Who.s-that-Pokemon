{"ast":null,"code":"import{useEffect,useState}from\"react\";export default function Timer(_ref){let{isAllOptionLocked,questionChanged,setGameOver}=_ref;const[timer,setTimer]=useState(10);useEffect(()=>{if(isAllOptionLocked)return setTimer(prev=>prev);if(timer===0)return setGameOver(true);const interval=setInterval(()=>{setTimer(prev=>prev-1);},1000);return()=>clearInterval(interval);},[timer,isAllOptionLocked,setGameOver]);useEffect(()=>{setTimer(30);},[questionChanged]);return timer;}","map":{"version":3,"names":["useEffect","useState","Timer","_ref","isAllOptionLocked","questionChanged","setGameOver","timer","setTimer","prev","interval","setInterval","clearInterval"],"sources":["D:/Projects/Who.s-that-Pokemon/src/components/timer/Timer.js"],"sourcesContent":["import { useEffect, useState } from \"react\";\r\n\r\nexport default function Timer({\r\n  isAllOptionLocked,\r\n  questionChanged,\r\n  setGameOver,\r\n}) {\r\n  const [timer, setTimer] = useState(10);\r\n  useEffect(() => {\r\n    if (isAllOptionLocked) return setTimer((prev) => prev);\r\n    if (timer === 0) return setGameOver(true);\r\n    const interval = setInterval(() => {\r\n      setTimer((prev) => prev - 1);\r\n    }, 1000);\r\n\r\n    return () => clearInterval(interval);\r\n  }, [timer, isAllOptionLocked, setGameOver]);\r\n\r\n  useEffect(() => {\r\n    setTimer(30);\r\n  }, [questionChanged]);\r\n\r\n  return timer;\r\n}\r\n"],"mappings":"AAAA,OAASA,SAAS,CAAEC,QAAQ,KAAQ,OAAO,CAE3C,cAAe,SAAS,CAAAC,KAAKA,CAAAC,IAAA,CAI1B,IAJ2B,CAC5BC,iBAAiB,CACjBC,eAAe,CACfC,WACF,CAAC,CAAAH,IAAA,CACC,KAAM,CAACI,KAAK,CAAEC,QAAQ,CAAC,CAAGP,QAAQ,CAAC,EAAE,CAAC,CACtCD,SAAS,CAAC,IAAM,CACd,GAAII,iBAAiB,CAAE,MAAO,CAAAI,QAAQ,CAAEC,IAAI,EAAKA,IAAI,CAAC,CACtD,GAAIF,KAAK,GAAK,CAAC,CAAE,MAAO,CAAAD,WAAW,CAAC,IAAI,CAAC,CACzC,KAAM,CAAAI,QAAQ,CAAGC,WAAW,CAAC,IAAM,CACjCH,QAAQ,CAAEC,IAAI,EAAKA,IAAI,CAAG,CAAC,CAAC,CAC9B,CAAC,CAAE,IAAI,CAAC,CAER,MAAO,IAAMG,aAAa,CAACF,QAAQ,CAAC,CACtC,CAAC,CAAE,CAACH,KAAK,CAAEH,iBAAiB,CAAEE,WAAW,CAAC,CA